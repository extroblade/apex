PORT=8080
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=app
# CORS allowlist (comma-separated origins). Empty = deny cross-origin, which is
# correct for the normal same-origin setup (nginx proxies /api). Only set this
# for direct cross-origin API access; never use "*" with cookie auth.
CORS_ORIGIN=http://localhost:3000
# Mark the session cookie Secure (HTTPS-only). Keep false for local http dev;
# set true in every TLS/production deploy.
COOKIE_SECURE=false
# MySQL root password (dev default "root"). Set a strong value in production and
# drop the host 3306 port mapping in backend/docker-compose.yml.
MYSQL_ROOT_PASSWORD=root
# base64-encoded 32-byte key for encrypting stored iRacing credentials.
# Generate one with:  head -c 32 /dev/urandom | base64
# Leave empty to disable the iRacing integration (its endpoints return 503).
# Each user links their OWN iRacing account in-app; there is no shared account.
APP_ENCRYPTION_KEY=

# iRacing OAuth client (register an app with iRacing to obtain these). The
# integration stays disabled until CLIENT_ID and REDIRECT_URI are set.
# The redirect URI must match what you registered and point at this API's
# callback, reachable via the SPA origin, e.g. http://localhost:3000/api/iracing/callback
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=
IRACING_OAUTH_REDIRECT_URI=http://localhost:3000/api/iracing/callback

# Redis cache (host:port). Fail-open — if empty or unreachable the app reads
# straight from MySQL. In Docker this is the compose service, e.g. redis:6379.
REDIS_ADDR=

# Cockpit dev-overlay key. When set, opening any page with ?dev=<key> stores a
# "developer" cookie that unlocks the runtime feature-flag toggles. Empty
# disables Cockpit entirely (the endpoints 404). The Docker stack defaults this
# to 3 (i.e. open http://localhost:3000/?dev=3).
# SECURITY: pick a long random value for any public deploy — whoever knows this
# key can flip your feature flags.
DEVELOPER_KEY=3

# Where the scheduler rehosts catalog images — the root of the shared media
# volume (which the static service mounts as its /catalog dir). Images go under
# cars/ and tracks/ and are served at /media/catalog/*. In Docker: /media-data.
CATALOG_IMAGE_DIR=

# Enable scraping the iRacing web catalog (iracing.com/cars|tracks) for artwork
# and marketing descriptions. OFF by default: those assets/text are iRacing's
# copyright, a legal risk for a commercial deploy. The factual catalog (ids,
# prices, schedule) and the app's own seeded descriptions work without it. Set
# to 1/true ONLY where you have the right to use that content.
IRACING_SCRAPE=
